<Window x:Class="CybersecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot - South Africa"
        Height="600" Width="800"
        MinHeight="500" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <!-- Main container -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header with ASCII art -->
            
            <RowDefinition Height="*"/>
            <!-- Chat area -->
            <RowDefinition Height="Auto"/>
            <!-- User info bar -->
            <RowDefinition Height="Auto"/>
            <!-- Sentiment bar -->
            <RowDefinition Height="Auto"/>
            <!-- Input area -->
        </Grid.RowDefinitions>

        <!-- We'll add controls here -->
        <Border Grid.Row="0" Background="#2C2C2C" BorderBrush="#555" BorderThickness="0,0,0,2">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <TextBlock x:Name="lblAsciiArt" 
                   FontFamily="Consolas" 
                   FontSize="10" 
                   Foreground="#00FFFF" 
                   Text="Loading ASCII art..." 
                   TextAlignment="Center"
                   Padding="10"
                   Background="#1E1E1E"/>
            </ScrollViewer>
        </Border>

        <!-- Chat Area -->
        <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,0,0,1">
            <ListBox x:Name="lstChatHistory" 
             Background="#1E1E1E" 
             Foreground="White" 
             FontFamily="Segoe UI" 
             FontSize="12"
             BorderThickness="0"
             Margin="10"
             ScrollViewer.VerticalScrollBarVisibility="Visible">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- User Info Bar -->
        <Border Grid.Row="2" Background="#2C2C2C" BorderBrush="#555" BorderThickness="0,1,0,1">
            <TextBlock x:Name="lblUserInfo" 
               Foreground="#90EE90" 
               FontSize="11" 
               Padding="10,5"
               Text="Not logged in"/>
        </Border>

        <!-- Sentiment Bar -->
        <Border Grid.Row="3" Background="#2C2C2C" BorderBrush="#555" BorderThickness="0,0,0,1">
            <TextBlock x:Name="lblSentiment" 
               Foreground="#FFFFE0" 
               FontSize="11" 
               Padding="10,5"
               Text="Mood detected: neutral"/>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="4" Background="#2C2C2C" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- TextBox takes remaining space -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Button fixed width -->
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtUserInput" 
                 Grid.Column="0"
                 FontSize="12" 
                 Padding="8"
                 Background="#3E3E3E" 
                 Foreground="White"
                 BorderThickness="1"
                 BorderBrush="#555"
                 VerticalAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <Button x:Name="btnSend" 
                Grid.Column="1"
                Content="Send" 
                Width="80" 
                Height="32" 
                Margin="10,0,0,0"
                Background="#0078D7" 
                Foreground="White"
                FontWeight="Bold"
                Cursor="Hand"
                VerticalAlignment="Center">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
       
    </Grid>
</Window>
